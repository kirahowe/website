{;; Base configuration — applies in every environment. Environment
 ;; specifics (where the content lives, git syncing) are in dev.edn and
 ;; prod.edn; `bb dev` and `bb run` pick the right one.

 ;; Displayed in the site header and the feed
 :site-title "Kira Howe"
 :site-description "My personal space on the internet"

 ;; Absolute base URL, no trailing slash — used for the feed and canonical links
 :base-url "https://kirahowe.com"

 ;; The home feed shows at least this many recent items, rounded up to
 ;; whole days, then links onward to the month archives.
 :home-entries 10

 ;; Entry types that may appear in frontmatter, in nav order.
 ;; A typo'd type in a content file fails indexing loudly.
 :entry-types [:post :note :link :quote :release :tool]

 ;; Command used by `bb suggest-tags` (invoked via your login shell, so
 ;; shell aliases/functions work). dev.edn can override it.
 :llm-command "claude"

 ;; NOTE: :port is environment-specific and lives in the env files —
 ;; dev.edn (8100) and prod.edn (8080, what Fly's Dockerfile expects) —
 ;; so the two environments can't collide on a port by accident.
 }
