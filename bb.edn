{;; nextjournal/markdown is built into bb as of 1.12.196 — the site has
 ;; zero external dependencies.
 :min-bb-version "1.12.196"

 :paths ["src" "resources" "test"]

 :tasks
 {dev {:doc "Start the dev server (config.edn + dev.edn; reindexes every request, drafts visible)"
       :requires ([site.core :as core])
       :task (core/start! {:env :dev :block? true})}

  run {:doc "Start the production server (config.edn + prod.edn)"
       :requires ([site.core :as core])
       :task (core/start! {:env :prod :block? true})}

  reindex {:doc "Validate + index all content, failing loudly on broken files"
           :requires ([site.author :as author])
           :task (author/reindex)}

  test {:doc "Run the test suite"
        :requires ([clojure.test :as t]
                   [site.config-test]
                   [site.content-test]
                   [site.routes-test]
                   [site.search-test]
                   [site.sync-test]
                   [site.views-test])
        :task (let [{:keys [fail error]} (t/run-all-tests (re-pattern "site\\..*-test"))]
                (when (pos? (+ fail error))
                  (System/exit 1)))}

  lint {:doc "Lint src and test with clj-kondo (must be on PATH)"
        :task (let [{:keys [exit]}
                    (shell {:continue true}
                           "clj-kondo --lint src test --fail-level error")]
                (System/exit exit))}

  new {:doc "Scaffold a new draft: bb new <type> <title words...>"
       :requires ([site.author :as author])
       :task (apply author/new-draft *command-line-args*)}

  publish {:doc "Publish a draft: bb publish <name> [--no-git] — lints it, moves it into today's date folder, commits, pushes"
           :requires ([site.author :as author])
           :task (apply author/publish *command-line-args*)}

  suggest-tags {:doc "Suggest tags for a draft with the configured LLM: bb suggest-tags <name>"
                :requires ([site.author :as author])
                :task (apply author/suggest-tags *command-line-args*)}}}
