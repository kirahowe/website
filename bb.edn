{;; nextjournal/markdown is built into bb as of 1.12.196 — the site has
 ;; zero external dependencies.
 :min-bb-version "1.12.196"

 :paths ["src" "resources" "test"]

 :tasks
 {dev {:doc "Start the dev server (config/config.edn + config/dev.edn; reindexes every request, drafts visible)"
       :requires ([site.core :as core])
       :task (core/start! {:env :dev :block? true})}

  prod {:doc "Start the production server (config/config.edn + config/prod.edn)"
        :requires ([site.core :as core])
        :task (core/start! {:env :prod :block? true})}

  reindex {:doc "Validate + index all content, failing loudly on broken files"
           :requires ([site.author :as author])
           :task (author/reindex)}

  test {:doc "Run the test suite"
        :requires ([clojure.test :as t]
                   [site.author-test]
                   [site.tui-test]
                   [site.config-test]
                   [site.content-test]
                   [site.routes-test]
                   [site.search-test]
                   [site.sync-test]
                   [site.views-test])
        :task (let [{:keys [fail error]} (t/run-all-tests (re-pattern "site\\..*-test"))]
                (when (pos? (+ fail error))
                  (System/exit 1)))}

  lint {:doc "Lint src and test with clj-kondo (must be on PATH)"
        :task (let [{:keys [exit]}
                    (shell {:continue true}
                           "clj-kondo --lint src test --fail-level error")]
                (System/exit exit))}

  new {:doc "Scaffold a new draft: bb new [type] [title words...] — with no type, pick one from the configured entry types"
       :requires ([site.author :as author])
       :task (apply author/new-draft *command-line-args*)}

  drafts {:doc "List every draft, marking which are queued to publish: bb drafts"
          :requires ([site.author :as author])
          :task (apply author/list-drafts *command-line-args*)}

  publish {:doc "Publish a draft: bb publish [<name>] [--no-git] — lints it, moves it into its date folder, commits, pushes; with no name at a terminal, pick a draft (or flush the queue); with no name in a script, publishes every draft marked publish: true"
           :requires ([site.author :as author])
           :task (apply author/publish *command-line-args*)}

  publish-queued {:doc "Same as bare `bb publish`: publishes every draft marked publish: true, then pushes: bb publish-queued [--no-git] (the stable name the autopublish agent invokes)"
                  :requires ([site.author :as author])
                  :task (apply author/publish-queued *command-line-args*)}

  autopublish {:doc "Manage the launchd agent that runs publish-queued every 5 min: bb autopublish install|uninstall|status"
               :requires ([site.author :as author])
               :task (apply author/autopublish *command-line-args*)}

  suggest-tags {:doc "Suggest tags with the configured LLM, then write the ones you pick into the entry: bb suggest-tags [<name>] — with no name, pick from any draft or published entry that has no tags yet"
                :requires ([site.author :as author])
                :task (apply author/suggest-tags *command-line-args*)}

  suggest-slug {:doc "Suggest URL slugs with the configured LLM, then write the one you pick (or type) into the draft: bb suggest-slug [<name>] — with no name, pick from any draft that has no slug yet"
                :requires ([site.author :as author])
                :task (apply author/suggest-slug *command-line-args*)}

  sync {:doc "Mirror the vault's published content into the publish repo and push (bb sync)"
        :requires ([site.author :as author])
        :task (apply author/sync-content *command-line-args*)}}}
